# TEMPLATE FILE — do NOT commit real secrets to Git.
#
# Create secrets with:
#   kubectl create secret generic discord-bot-secrets \
#     --namespace=cityflow \
#     --from-literal=DISCORD_TOKEN="your-bot-token" \
#     --from-literal=DISCORD_CLIENT_ID="your-client-id" \
#     --from-literal=DISCORD_GUILD_ID="your-guild-id" \
#     --dry-run=client -o yaml | kubectl apply -f -
apiVersion: v1
kind: Secret
metadata:
  name: discord-bot-secrets
  namespace: cityflow
  labels:
    app.kubernetes.io/name: discord-bot
    app.kubernetes.io/part-of: cityflow
type: Opaque
stringData:
  DISCORD_TOKEN: "REPLACE_WITH_BOT_TOKEN"
  DISCORD_CLIENT_ID: "REPLACE_WITH_CLIENT_ID"
  DISCORD_GUILD_ID: "REPLACE_WITH_GUILD_ID"
  MONGODB_URI: "mongodb://cityflow:REPLACE_PASSWORD@cityflow-mongodb-0.cityflow-mongodb:27017/cityflow-bot?authSource=admin"
  BOT_API_KEY: "REPLACE_WITH_SECURE_API_KEY"
