# TEMPLATE FILE — do NOT commit real secrets to Git.
#
# Create secrets with:
#   MONGO_PASS=$(openssl rand -base64 24)
#   kubectl create secret generic mongodb-credentials \
#     --namespace=cityflow \
#     --from-literal=username=cityflow \
#     --from-literal=password="$MONGO_PASS" \
#     --dry-run=client -o yaml | kubectl apply -f -
#
#   kubectl create secret generic backend-secrets \
#     --namespace=cityflow \
#     --from-literal=MONGODB_URI="mongodb://cityflow:$MONGO_PASS@cityflow-mongodb-0.cityflow-mongodb:27017/cityflow?authSource=admin" \
#     --from-literal=JWT_SECRET="$(openssl rand -base64 32)" \
#     --from-literal=ADMIN_PASSWORD="$(openssl rand -base64 16)" \
#     --from-literal=SMTP_USER="<your-brevo-smtp-login>" \
#     --from-literal=SMTP_PASS="<your-brevo-smtp-key>" \
#     --from-literal=EMAIL_FROM="noreply@sizops.co.il" \
#     --from-literal=FRONTEND_URL="https://cityflow.sizops.co.il" \
#     --dry-run=client -o yaml | kubectl apply -f -
apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: cityflow
  labels:
    app.kubernetes.io/name: backend
    app.kubernetes.io/part-of: cityflow
type: Opaque
stringData:
  MONGODB_URI: "mongodb://cityflow:REPLACE_PASSWORD@cityflow-mongodb-0.cityflow-mongodb:27017/cityflow?authSource=admin"
  JWT_SECRET: "REPLACE_WITH_A_SECURE_RANDOM_STRING"
  ADMIN_PASSWORD: "REPLACE_WITH_A_SECURE_PASSWORD"
  SMTP_USER: "REPLACE_WITH_BREVO_SMTP_LOGIN"
  SMTP_PASS: "REPLACE_WITH_BREVO_SMTP_KEY"
  EMAIL_FROM: "noreply@sizops.co.il"
  FRONTEND_URL: "https://cityflow.sizops.co.il"
