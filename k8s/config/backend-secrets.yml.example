# TEMPLATE FILE — do NOT commit real secrets to Git.
# Create the actual Secret using:
#   kubectl apply -f k8s/config/backend-secrets.yml
#
# Or generate from a file:
#   kubectl create secret generic backend-secrets \
#     --namespace=cityflow \
#     --from-literal=MONGODB_URI='mongodb://...' \
#     --from-literal=JWT_SECRET='your-secret' \
#     --from-literal=ADMIN_PASSWORD='your-password' \
#     --dry-run=client -o yaml | kubectl apply -f -
apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: cityflow
  labels:
    app.kubernetes.io/name: backend
    app.kubernetes.io/part-of: cityflow
type: Opaque
stringData:
  MONGODB_URI: "mongodb://cityflow-mongodb-0.cityflow-mongodb:27017/cityflow?replicaSet=rs0"
  JWT_SECRET: "REPLACE_WITH_A_SECURE_RANDOM_STRING"
  ADMIN_PASSWORD: "REPLACE_WITH_A_SECURE_PASSWORD"
